<?xml version="1.0" encoding="utf-8"?>
<!-- Modular XML file to be used for displaying friends -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#16161F"
    android:padding="18dp"
    android:layout_marginBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <!-- Avatar circle -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp" >
            <TextView
                android:id="@+id/friend_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FF5C5C"
                android:gravity="center"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="XD"
                android:textColor="#FFFFFF"
                android:textSize="17dp"
                android:textStyle="bold"
                android:padding="0dp" />
            <!--
            Contains the actual profile picture
            Invisible (no source or background) if pfp doesnt exist
            - Branden
            -->
            <ImageView
                android:id="@+id/friend_pfp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0000"
                android:src="#0000"
                android:scaleType="centerCrop"
                android:gravity="center"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">

            <TextView
                android:id="@+id/friend_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="Name Placeholder" />

            <TextView
                android:id="@+id/friend_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8888A4"
                android:textSize="12sp"
                android:text="Location" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_add_friend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:backgroundTint="#2ECC71"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone" />

        <!-- Arrow pinned to top-right corner of the card -->
        <TextView
            android:id="@+id/btn_view_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:text="➡"
            android:textColor="#8888A4"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/friend_bio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#8888A4"
        android:textSize="13sp"
        android:maxLines="2"
        android:text="User bio goes here..." />

    <TextView
        android:id="@+id/friend_current_activity_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="I Am Currently:"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/friend_current_activity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#8888A4"
        android:textSize="13sp"
        android:text="" />

    <LinearLayout
        android:id="@+id/friend_interests_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp" />


</LinearLayout>