<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/filter"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14"
    tools:context=".FilterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

    <!-- TOP BAR  –  title + filter button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <!-- Title block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Profile"
                android:textColor="#FFFFFF"
                android:textSize="20dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8888A4"
                android:textSize="12dp"
                android:text="How your profile appears in search" />

        </LinearLayout>

        <!-- Edit button -->
        <Button
            android:id="@+id/edit_profile_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit"
            android:textColor="#FFFFFF"
            android:textSize="16dp"
            android:backgroundTint="#2A2A38" />

        <Button
            android:id="@+id/btn_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log Out"
            android:textColor="#FFFFFF"
            android:textSize="13dp"
            android:backgroundTint="#FF5C5C"
            android:layout_marginStart="8dp" />


    </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp">

            <!-- DUMMY CARD 1,for real data-->
            <LinearLayout
                android:id="@+id/card_person_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#16161F"
                android:padding="18dp"
                android:layout_marginBottom="14dp">

                <!-- Header: avatar, name/town, match % -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="0dp">

                    <!-- Avatar circle -->
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp" >
                        <Button
                            android:id="@+id/avatar_1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#FF5C5C"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="XD"
                            android:textColor="#FFFFFF"
                            android:textSize="17dp"
                            android:textStyle="bold"
                            android:padding="0dp"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            app:iconPadding="0dp" />
                        <!--
                        Contains the actual profile picture
                        Invisible (no source or background) if pfp doesnt exist
                        - Branden
                        -->
                        <ImageView
                            android:id="@+id/pfp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#0000"
                            android:src="#0000"
                            android:scaleType="centerCrop"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            app:iconPadding="0dp" />
                    </FrameLayout>

                    <!-- Name + distance -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp">

                        <EditText
                            android:id="@+id/profileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="15dp"
                            android:textStyle="bold"
                            android:inputType="text"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:hint="Enter name, age..."
                            android:textColorHint="#FFFFFF"
                            android:text="Name" />

                        <EditText
                            android:id="@+id/profileLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#8888A4"
                            android:textSize="12dp"
                            android:inputType="text"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:hint="Enter Location..."
                            android:textColorHint="#8888A4"
                            android:text="Enter Location..." />

                    </LinearLayout>
                </LinearLayout>

                <!-- Bio -->
                <EditText
                    android:id="@+id/profileDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="0dp"
                    android:textColor="#8888A4"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:inputType="textMultiLine"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:hint="Enter bio..."
                    android:textColorHint="#8888A4"
                    android:text="Enter bio..." />

                <!-- Interest chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/chip1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="7dp"
                        android:text=""
                        android:textColor="#8888A4"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:background="#0D0D14"/>

                    <EditText
                        android:id="@+id/chip2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="7dp"
                        android:text=""
                        android:textColor="#8888A4"
                        android:textSize="11dp"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:background="#0D0D14"/>

                    <EditText
                        android:id="@+id/chip3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#8888A4"
                        android:textSize="11dp"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:background="#0D0D14"/>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1C1C28"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:translationY="0dp"
        android:elevation="16dp"
        android:visibility="gone">

        <!-- Sheet drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:background="#30FFFFFF" />

        <!-- Sheet title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Choose Interest"
                android:textColor="#E8E8F0"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_clear_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear all"
                android:textColor="#FF5C5C"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="20dp"
            android:text="Show people you are interested in these"
            android:textColor="#8888A4"
            android:textSize="13sp" />

        <!-- Interest filter chips, row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/chip_music"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Music"
                android:textColor="#8888A4"
                android:textSize="13dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

            <TextView
                android:id="@+id/chip_hiking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Hiking"
                android:textColor="#8888A4"
                android:textSize="13dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

            <TextView
                android:id="@+id/chip_cooking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cooking"
                android:textColor="#8888A4"
                android:textSize="13dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

        </LinearLayout>

        <!-- Interest filter chips, row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/chip_gaming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Gaming"
                android:textColor="#8888A4"
                android:textSize="13dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

            <TextView
                android:id="@+id/chip_reading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Reading"
                android:textColor="#8888A4"
                android:textSize="13sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

            <TextView
                android:id="@+id/chip_travel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Travel"
                android:textColor="#8888A4"
                android:textSize="13sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

        </LinearLayout>

        <!-- Interest filter chips, row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/chip_merge_dragons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Merge Dragons"
                android:textColor="#8888A4"
                android:textSize="13dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

            <TextView
                android:id="@+id/chip_coding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Coding"
                android:textColor="#8888A4"
                android:textSize="13dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

            <TextView
                android:id="@+id/chip_disc_golf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disc Golf"
                android:textColor="#8888A4"
                android:textSize="13sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:background="#16161F"/>

        </LinearLayout>
    </LinearLayout>
        <include
            layout="@layout/nav_bar"
            android:layout_width="match_parent"
            android:layout_height="60dp" />
</LinearLayout>