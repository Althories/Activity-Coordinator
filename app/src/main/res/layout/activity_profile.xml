<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/filter"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14"
    tools:context=".FilterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

    <!-- TOP BAR  –  title + filter button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <!-- Title block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Profile"
                android:textColor="#FFFFFF"
                android:textSize="20dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8888A4"
                android:textSize="12dp"
                android:text="How your profile appears in search" />

        </LinearLayout>

        <!-- Edit button -->
        <Button
            android:id="@+id/edit_profile_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit"
            android:textColor="#FFFFFF"
            android:textSize="16dp"
            android:backgroundTint="#2A2A38" />

        <Button
            android:id="@+id/btn_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log Out"
            android:textColor="#FFFFFF"
            android:textSize="13dp"
            android:backgroundTint="#FF5C5C"
            android:layout_marginStart="8dp" />


    </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp">

            <!-- DUMMY CARD 1,for real data-->
            <LinearLayout
                android:id="@+id/card_person_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#16161F"
                android:padding="18dp"
                android:layout_marginBottom="14dp">

                <!-- Header: avatar, name/town, match % -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="0dp">

                    <!-- Avatar circle -->
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp" >
                        <Button
                            android:id="@+id/avatar_1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#FF5C5C"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="CP"
                            android:textColor="#FFFFFF"
                            android:textSize="17dp"
                            android:textStyle="bold"
                            android:padding="0dp"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            app:iconPadding="0dp" />
                        <!--
                        Contains the actual profile picture
                        Invisible (no source or background) if pfp doesnt exist
                        - Branden
                        -->
                        <ImageView
                            android:id="@+id/pfp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#0000"
                            android:src="#0000"
                            android:scaleType="centerCrop"
                            android:gravity="center"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            app:iconPadding="0dp" />
                        <ImageView
                            android:id="@+id/editIndicator"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>
                    </FrameLayout>

                    <!-- Name + distance -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp">

                        <EditText
                            android:id="@+id/profileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="15dp"
                            android:textStyle="bold"
                            android:inputType="text"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:hint="Enter name, age..."
                            android:textColorHint="#FFFFFF"
                            android:text="Cooper Ptacek, 21" />

                        <EditText
                            android:id="@+id/profileLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#8888A4"
                            android:textSize="12dp"
                            android:inputType="text"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:hint="Enter Location..."
                            android:textColorHint="#8888A4"
                            android:text="Forest Lake, MN" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Bio -->
                <EditText
                    android:id="@+id/profileDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="0dp"
                    android:textColor="#8888A4"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:inputType="textMultiLine"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:hint="Enter bio..."
                    android:textColorHint="#8888A4"
                    android:text="Statistics and Computer Science Major at Gustavus Adolphus College. Professional Nerd." />

                <!-- Interest chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="7dp"
                        android:text="Music"
                        android:textColor="#8888A4"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:background="#0D0D14"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="7dp"
                        android:text="Hiking"
                        android:textColor="#8888A4"
                        android:textSize="11dp"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:background="#0D0D14"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disc Golf"
                        android:textColor="#8888A4"
                        android:textSize="11dp"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:background="#0D0D14"/>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <include
        layout="@layout/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp" />
</LinearLayout>