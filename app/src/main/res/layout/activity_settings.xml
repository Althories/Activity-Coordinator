<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14"
    tools:context=".SettingsActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="48dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#8888A4"
                        android:textSize="12sp"
                        android:text="Manage your account" />

                </LinearLayout>

            </LinearLayout>

            <!-- ACCOUNT SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNT"
                android:textColor="#8888A4"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Change Email Card -->
                <LinearLayout
                    android:id="@+id/section_change_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#16161F"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <!-- Collapsed header row -->
                    <LinearLayout
                        android:id="@+id/email_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Change Email"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/email_current_display"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="your@email.com"
                                android:textColor="#8888A4"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/email_chevron"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▼"
                            android:textColor="#8888A4"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <!-- Expanded email form (gone by default) -->
                    <LinearLayout
                        android:id="@+id/email_form"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="12dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#22222F"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="New Email"
                            android:textColor="#8888A4"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_new_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:hint="Enter new email"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555568"
                            android:background="#0D0D14"
                            android:padding="10dp"
                            android:textSize="13sp"
                            android:layout_marginBottom="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Password (to confirm)"
                            android:textColor="#8888A4"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_email_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:hint="Enter current password"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555568"
                            android:background="#0D0D14"
                            android:padding="10dp"
                            android:textSize="13sp"
                            android:layout_marginBottom="10dp"/>

                        <TextView
                            android:id="@+id/tv_email_error"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FF5C5C"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:layout_marginBottom="8dp"/>

                        <Button
                            android:id="@+id/btn_save_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Save Email"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:backgroundTint="#2A2A38"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- Divider between cards -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0D0D14"/>

                <!-- Change Password Card -->
                <LinearLayout
                    android:id="@+id/section_change_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#16161F"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <!-- Collapsed header row -->
                    <LinearLayout
                        android:id="@+id/password_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Change Password"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Update your login password"
                                android:textColor="#8888A4"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/password_chevron"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▼"
                            android:textColor="#8888A4"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <!-- Expanded password form (gone by default) -->
                    <LinearLayout
                        android:id="@+id/password_form"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="12dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#22222F"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Password"
                            android:textColor="#8888A4"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_current_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:hint="Enter current password"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555568"
                            android:background="#0D0D14"
                            android:padding="10dp"
                            android:textSize="13sp"
                            android:layout_marginBottom="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="New Password"
                            android:textColor="#8888A4"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_new_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:hint="At least 6 characters"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555568"
                            android:background="#0D0D14"
                            android:padding="10dp"
                            android:textSize="13sp"
                            android:layout_marginBottom="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Confirm New Password"
                            android:textColor="#8888A4"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_confirm_new_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:hint="Re-enter new password"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555568"
                            android:background="#0D0D14"
                            android:padding="10dp"
                            android:textSize="13sp"
                            android:layout_marginBottom="10dp"/>

                        <TextView
                            android:id="@+id/tv_password_error"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FF5C5C"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:layout_marginBottom="8dp"/>

                        <Button
                            android:id="@+id/btn_save_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Save Password"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:backgroundTint="#2A2A38"/>

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- PRIVACY SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRIVACY"
                android:textColor="#8888A4"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Exact Name Search Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#16161F"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="22dp"
                    android:paddingBottom="22dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Exact Name Search Only"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_exact_search_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Only appear when your full name is searched"
                            android:textColor="#8888A4"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/toggle_exact_name_search"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="#8888A4"
                        android:trackTint="#2A2A38"/>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#0D0D14"/>

                <!-- Blocked Users Row -->
                <LinearLayout
                    android:id="@+id/btn_blocked_users"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#16161F"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="22dp"
                    android:paddingBottom="22dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blocked Users"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View and manage blocked accounts"
                            android:textColor="#8888A4"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#8888A4"
                        android:textSize="20sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- SESSION SECTION  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESSION"
                android:textColor="#8888A4"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="18dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="32dp">

                <Button
                    android:id="@+id/btn_logout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Log Out"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#FF5C5C"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include
        layout="@layout/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp" />

</LinearLayout>