<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/search_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Friends"
                android:textColor="#FFFFFF"
                android:textSize="20dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/search_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search by name or interest"
                android:textColor="#8888A4"
                android:textSize="12dp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- SEARCH BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search name or interest..."
                android:textColor="#FFFFFF"
                android:textColorHint="#8888A4"
                android:textSize="14dp"
                android:background="#16161F"
                android:backgroundTint="#16161F"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:inputType="text"
                android:singleLine="true" />

            <Button
                android:id="@+id/btn_clear_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textColor="#FFFFFF"
                android:textSize="13dp"
                android:backgroundTint="#2A2A38"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- INTEREST FILTER CHIPS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/layout_search_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            </LinearLayout>

        </HorizontalScrollView>

        <!-- RESULTS LIST -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp">

                <!-- CARD 1 -->
                <LinearLayout
                    android:id="@+id/search_card_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#16161F"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="17dp"
                            android:textStyle="bold"
                            android:background="#FF5C5C"
                            android:text="CP" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cooper Ptacek, 21"
                                android:textColor="#FFFFFF"
                                android:textSize="15dp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Forest Lake, MN"
                                android:textColor="#8888A4"
                                android:textSize="12dp" />

                        </LinearLayout>

                        <Button
                            android:id="@+id/btn_add_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ Add"
                            android:textColor="#FFFFFF"
                            android:textSize="12dp"
                            android:backgroundTint="#2ECC71"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Statistics and CS Major at Gustavus. Professional Nerd."
                        android:textColor="#8888A4"
                        android:textSize="13dp"
                        android:maxLines="2"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:text="Music"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:text="Hiking"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gaming"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                    </LinearLayout>

                </LinearLayout>

                <!-- CARD 2 -->
                <LinearLayout
                    android:id="@+id/search_card_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#16161F"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="17dp"
                            android:textStyle="bold"
                            android:background="#00D4B4"
                            android:text="NK" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nik Kopek, 21"
                                android:textColor="#FFFFFF"
                                android:textSize="15dp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Saint Peter, MN"
                                android:textColor="#8888A4"
                                android:textSize="12dp" />

                        </LinearLayout>

                        <Button
                            android:id="@+id/btn_add_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ Add"
                            android:textColor="#FFFFFF"
                            android:textSize="12dp"
                            android:backgroundTint="#2ECC71"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Full time Scrum Lord."
                        android:textColor="#8888A4"
                        android:textSize="13dp"
                        android:maxLines="2"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:text="Gaming"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:text="Reading"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Music"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                    </LinearLayout>

                </LinearLayout>

                <!-- CARD 3 -->
                <LinearLayout
                    android:id="@+id/search_card_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#16161F"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="17dp"
                            android:textStyle="bold"
                            android:background="#FFBC42"
                            android:text="BS" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BMCP Solhjem"
                                android:textColor="#FFFFFF"
                                android:textSize="15dp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fargo, ND"
                                android:textColor="#8888A4"
                                android:textSize="12dp" />

                        </LinearLayout>

                        <Button
                            android:id="@+id/btn_add_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ Add"
                            android:textColor="#FFFFFF"
                            android:textSize="12dp"
                            android:backgroundTint="#2ECC71"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Biggest hindrance to the group - Louis"
                        android:textColor="#8888A4"
                        android:textSize="13dp"
                        android:maxLines="2"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:text="Merge Dragons"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:text="Merge Dragons"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Merge Dragons"
                            android:textColor="#8888A4"
                            android:textSize="11dp"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="#0D0D14" />

                    </LinearLayout>

                </LinearLayout>

                <!-- EMPTY STATE -->
                <LinearLayout
                    android:id="@+id/layout_no_results"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="48dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No results found"
                        android:textColor="#FFFFFF"
                        android:textSize="18dp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Try a different name or interest"
                        android:textColor="#8888A4"
                        android:textSize="13dp"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <include
        layout="@layout/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp" />

</LinearLayout>